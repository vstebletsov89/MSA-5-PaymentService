          <dc:Bounds x="1053" y="120" width="55" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_Merge" bpmnElement="GW_ApprovedMerge" isMarkerVisible="true">
        <dc:Bounds x="1155" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_ParSplit" bpmnElement="GW_ParallelSplit">
        <dc:Bounds x="1250" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Transfer" bpmnElement="Task_TransferMerchant">
