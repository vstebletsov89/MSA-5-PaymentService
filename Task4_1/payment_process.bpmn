      <bpmndi:BPMNShape id="S_Fraud" bpmnElement="Task_FraudCheck">
        <dc:Bounds x="570" y="260" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_Fraud" bpmnElement="GW_FraudDecision" isMarkerVisible="true">
