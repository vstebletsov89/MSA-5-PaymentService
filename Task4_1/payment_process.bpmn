<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_OrchestrPay" targetNamespace="http://orchestrpay.com/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <bpmn:process id="Process_Payment" name="OrchestrPay Payment Process" isExecutable="true">
    <bpmn:startEvent id="Start" name="Платёж инициирован">
      <bpmn:outgoing>F_start_create</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CreatePayment" name="Создать платёж">
      <bpmn:incoming>F_start_create</bpmn:incoming>
      <bpmn:outgoing>F_create_reserve</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ReserveFunds" name="Списать средства">
      <bpmn:incoming>F_create_reserve</bpmn:incoming>
      <bpmn:outgoing>F_reserve_fraud</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_FraudCheck" name="Проверка на антифрод">
      <bpmn:incoming>F_reserve_fraud</bpmn:incoming>
      <bpmn:outgoing>F_fraud_gw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_FraudDecision" name="Результат проверки">
      <bpmn:incoming>F_fraud_gw</bpmn:incoming>
      <bpmn:outgoing>F_fraud_ok</bpmn:outgoing>
      <bpmn:outgoing>F_fraud_reject</bpmn:outgoing>
      <bpmn:outgoing>F_fraud_manual</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:receiveTask id="Task_ManualReview" name="Ожидание ручного подтверждения">
      <bpmn:incoming>F_fraud_manual</bpmn:incoming>
      <bpmn:outgoing>F_manual_gw</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:boundaryEvent id="Boundary_CutOff" name="Cut-off 20 мин" attachedToRef="Task_ManualReview">
      <bpmn:outgoing>F_cutoff_merge</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT20M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="GW_ManualDecision" name="Решение оператора">
      <bpmn:incoming>F_manual_gw</bpmn:incoming>
      <bpmn:outgoing>F_manual_ok</bpmn:outgoing>
      <bpmn:outgoing>F_manual_reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_ApprovedMerge">
      <bpmn:incoming>F_fraud_ok</bpmn:incoming>
      <bpmn:incoming>F_manual_ok</bpmn:incoming>
      <bpmn:incoming>F_cutoff_merge</bpmn:incoming>
      <bpmn:outgoing>F_merge_transfer</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="GW_ParallelSplit">
      <bpmn:incoming>F_merge_transfer</bpmn:incoming>
      <bpmn:outgoing>F_par_transfer</bpmn:outgoing>
      <bpmn:outgoing>F_par_notify_success</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_TransferMerchant" name="Перевод контрагенту">
      <bpmn:incoming>F_par_transfer</bpmn:incoming>
      <bpmn:outgoing>F_transfer_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Task_NotifySuccess" name="Отправка уведомления&#10;об успешной оплате">
      <bpmn:incoming>F_par_notify_success</bpmn:incoming>
      <bpmn:outgoing>F_notify_join</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:parallelGateway id="GW_ParallelJoin">
      <bpmn:incoming>F_transfer_join</bpmn:incoming>
      <bpmn:incoming>F_notify_join</bpmn:incoming>
      <bpmn:outgoing>F_join_end_ok</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:endEvent id="End_Success" name="Платёж завершён">
      <bpmn:incoming>F_join_end_ok</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_RejectMerge">
      <bpmn:incoming>F_fraud_reject</bpmn:incoming>
      <bpmn:incoming>F_manual_reject</bpmn:incoming>
      <bpmn:outgoing>F_reject_parallel</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="GW_RejectParSplit">
      <bpmn:incoming>F_reject_parallel</bpmn:incoming>
      <bpmn:outgoing>F_par_cancel</bpmn:outgoing>
      <bpmn:outgoing>F_par_notify_reject</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_CancelPayment" name="Возврат средств клиенту">
      <bpmn:incoming>F_par_cancel</bpmn:incoming>
      <bpmn:outgoing>F_cancel_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Task_NotifyReject" name="Отправка уведомления&#10;об отмене заявки">
      <bpmn:incoming>F_par_notify_reject</bpmn:incoming>
      <bpmn:outgoing>F_notify_reject_join</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:parallelGateway id="GW_RejectParJoin">
      <bpmn:incoming>F_cancel_join</bpmn:incoming>
      <bpmn:incoming>F_notify_reject_join</bpmn:incoming>
      <bpmn:outgoing>F_join_end_reject</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:endEvent id="End_Reject" name="Заявка отменена">
      <bpmn:incoming>F_join_end_reject</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_start_create" sourceRef="Start" targetRef="Task_CreatePayment" />
    <bpmn:sequenceFlow id="F_create_reserve" sourceRef="Task_CreatePayment" targetRef="Task_ReserveFunds" />
    <bpmn:sequenceFlow id="F_reserve_fraud" sourceRef="Task_ReserveFunds" targetRef="Task_FraudCheck" />
    <bpmn:sequenceFlow id="F_fraud_gw" sourceRef="Task_FraudCheck" targetRef="GW_FraudDecision" />
    <bpmn:sequenceFlow id="F_fraud_ok" name="Пройдена" sourceRef="GW_FraudDecision" targetRef="GW_ApprovedMerge" />
    <bpmn:sequenceFlow id="F_fraud_reject" name="Не пройдена" sourceRef="GW_FraudDecision" targetRef="GW_RejectMerge" />
    <bpmn:sequenceFlow id="F_fraud_manual" name="Требуется ручное&#10;подтверждение" sourceRef="GW_FraudDecision" targetRef="Task_ManualReview" />
    <bpmn:sequenceFlow id="F_manual_gw" sourceRef="Task_ManualReview" targetRef="GW_ManualDecision" />
    <bpmn:sequenceFlow id="F_cutoff_merge" name="Истечение срока" sourceRef="Boundary_CutOff" targetRef="GW_ApprovedMerge" />
    <bpmn:sequenceFlow id="F_manual_ok" name="Ручное подтверждение" sourceRef="GW_ManualDecision" targetRef="GW_ApprovedMerge" />
    <bpmn:sequenceFlow id="F_manual_reject" name="Ручной отказ&#10;антифрод" sourceRef="GW_ManualDecision" targetRef="GW_RejectMerge" />
    <bpmn:sequenceFlow id="F_merge_transfer" sourceRef="GW_ApprovedMerge" targetRef="GW_ParallelSplit" />
    <bpmn:sequenceFlow id="F_par_transfer" sourceRef="GW_ParallelSplit" targetRef="Task_TransferMerchant" />
    <bpmn:sequenceFlow id="F_par_notify_success" sourceRef="GW_ParallelSplit" targetRef="Task_NotifySuccess" />
    <bpmn:sequenceFlow id="F_transfer_join" sourceRef="Task_TransferMerchant" targetRef="GW_ParallelJoin" />
    <bpmn:sequenceFlow id="F_notify_join" sourceRef="Task_NotifySuccess" targetRef="GW_ParallelJoin" />
    <bpmn:sequenceFlow id="F_join_end_ok" sourceRef="GW_ParallelJoin" targetRef="End_Success" />
    <bpmn:sequenceFlow id="F_reject_parallel" sourceRef="GW_RejectMerge" targetRef="GW_RejectParSplit" />
    <bpmn:sequenceFlow id="F_par_cancel" sourceRef="GW_RejectParSplit" targetRef="Task_CancelPayment" />
    <bpmn:sequenceFlow id="F_par_notify_reject" sourceRef="GW_RejectParSplit" targetRef="Task_NotifyReject" />
    <bpmn:sequenceFlow id="F_cancel_join" sourceRef="Task_CancelPayment" targetRef="GW_RejectParJoin" />
    <bpmn:sequenceFlow id="F_notify_reject_join" sourceRef="Task_NotifyReject" targetRef="GW_RejectParJoin" />
    <bpmn:sequenceFlow id="F_join_end_reject" sourceRef="GW_RejectParJoin" targetRef="End_Reject" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_Payment">
      <bpmndi:BPMNShape id="S_Start" bpmnElement="Start">
        <dc:Bounds x="170" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="154" y="325" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Create" bpmnElement="Task_CreatePayment">
        <dc:Bounds x="250" y="260" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Reserve" bpmnElement="Task_ReserveFunds">
