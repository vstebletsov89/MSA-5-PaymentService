      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_NotifySuccess" bpmnElement="Task_NotifySuccess">
        <dc:Bounds x="1340" y="340" width="140" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_ParJoin" bpmnElement="GW_ParallelJoin">
        <dc:Bounds x="1520" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndOK" bpmnElement="End_Success">
        <dc:Bounds x="1610" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1603" y="325" width="51" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_RejectMerge" bpmnElement="GW_RejectMerge" isMarkerVisible="true">
        <dc:Bounds x="955" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_RejParSplit" bpmnElement="GW_RejectParSplit">
        <dc:Bounds x="1055" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Cancel" bpmnElement="Task_CancelPayment">
        <dc:Bounds x="1150" y="400" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_NotifyReject" bpmnElement="Task_NotifyReject">
        <dc:Bounds x="1150" y="520" width="140" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_RejParJoin" bpmnElement="GW_RejectParJoin">
        <dc:Bounds x="1330" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndReject" bpmnElement="End_Reject">
        <dc:Bounds x="1420" y="472" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1394" y="515" width="89" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Boundary" bpmnElement="Boundary_CutOff">
        <dc:Bounds x="994" y="194" width="32" height="32" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1017" y="228" width="71" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_start_create" bpmnElement="F_start_create">
        <di:waypoint x="206" y="300" />
        <di:waypoint x="250" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_create_reserve" bpmnElement="F_create_reserve">
        <di:waypoint x="370" y="300" />
        <di:waypoint x="410" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_reserve_fraud" bpmnElement="F_reserve_fraud">
        <di:waypoint x="530" y="300" />
        <di:waypoint x="570" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_fraud_gw" bpmnElement="F_fraud_gw">
        <di:waypoint x="690" y="300" />
        <di:waypoint x="735" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_fraud_ok" bpmnElement="F_fraud_ok">
        <di:waypoint x="785" y="300" />
        <di:waypoint x="1155" y="300" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="949" y="282" width="52" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_fraud_reject" bpmnElement="F_fraud_reject">
        <di:waypoint x="760" y="325" />
        <di:waypoint x="760" y="490" />
        <di:waypoint x="955" y="490" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="767" y="400" width="67" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_fraud_manual" bpmnElement="F_fraud_manual">
        <di:waypoint x="760" y="275" />
        <di:waypoint x="760" y="170" />
        <di:waypoint x="850" y="170" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="767" y="210" width="81" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_manual_gw" bpmnElement="F_manual_gw">
        <di:waypoint x="1010" y="170" />
        <di:waypoint x="1055" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_manual_ok" bpmnElement="F_manual_ok">
        <di:waypoint x="1105" y="170" />
        <di:waypoint x="1180" y="170" />
        <di:waypoint x="1180" y="275" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1109" y="136" width="81" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_manual_reject" bpmnElement="F_manual_reject">
        <di:waypoint x="1080" y="195" />
        <di:waypoint x="1080" y="340" />
        <di:waypoint x="980" y="340" />
        <di:waypoint x="980" y="465" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="996" y="350" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_cutoff" bpmnElement="F_cutoff_merge">
        <di:waypoint x="1010" y="226" />
        <di:waypoint x="1010" y="260" />
        <di:waypoint x="1180" y="260" />
        <di:waypoint x="1180" y="275" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1086" y="242" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_merge_par" bpmnElement="F_merge_transfer">
        <di:waypoint x="1205" y="300" />
        <di:waypoint x="1250" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_par_transfer" bpmnElement="F_par_transfer">
        <di:waypoint x="1275" y="275" />
        <di:waypoint x="1275" y="235" />
        <di:waypoint x="1340" y="235" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_par_notify" bpmnElement="F_par_notify_success">
        <di:waypoint x="1275" y="325" />
        <di:waypoint x="1275" y="375" />
        <di:waypoint x="1340" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_transfer_join" bpmnElement="F_transfer_join">
        <di:waypoint x="1480" y="235" />
        <di:waypoint x="1545" y="235" />
        <di:waypoint x="1545" y="275" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_notify_join" bpmnElement="F_notify_join">
        <di:waypoint x="1480" y="375" />
        <di:waypoint x="1545" y="375" />
        <di:waypoint x="1545" y="325" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_join_end" bpmnElement="F_join_end_ok">
        <di:waypoint x="1570" y="300" />
        <di:waypoint x="1610" y="300" />
      </bpmndi:BPMNEdge>
