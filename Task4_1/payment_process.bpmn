        <di:waypoint x="1170" y="250" />
        <di:waypoint x="1170" y="275" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1076" y="216" width="87" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_manual_ok" bpmnElement="F_manual_ok">
        <di:waypoint x="1090" y="140" />
        <di:waypoint x="1170" y="140" />
        <di:waypoint x="1170" y="275" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1085" y="146" width="81" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_manual_reject" bpmnElement="F_manual_reject">
        <di:waypoint x="1065" y="165" />
        <di:waypoint x="1065" y="340" />
        <di:waypoint x="970" y="340" />
        <di:waypoint x="970" y="505" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="984" y="355" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_merge_transfer" bpmnElement="F_merge_transfer">
        <di:waypoint x="1195" y="300" />
        <di:waypoint x="1240" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_transfer_pivot" bpmnElement="F_transfer_pivot">
        <di:waypoint x="1380" y="300" />
        <di:waypoint x="1425" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_pivot_success" bpmnElement="F_pivot_success">
        <di:waypoint x="1450" y="275" />
        <di:waypoint x="1450" y="215" />
        <di:waypoint x="1520" y="215" />
        <bpmndi:BPMNLabel>
