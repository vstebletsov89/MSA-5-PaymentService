        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_RefundComp" bpmnElement="Task_RefundAfterPivot">
        <dc:Bounds x="1700" y="370" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_NotifyComp" bpmnElement="Task_NotifyRejectComp">
        <dc:Bounds x="1870" y="370" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndComp" bpmnElement="End_Compensated">
        <dc:Bounds x="2042" y="387" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2016" y="430" width="89" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_RejectMerge" bpmnElement="GW_RejectMerge" isMarkerVisible="true">
        <dc:Bounds x="945" y="505" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_RefundRej" bpmnElement="Task_RefundReject">
        <dc:Bounds x="1040" y="495" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_NotifyRej" bpmnElement="Task_NotifyReject">
        <dc:Bounds x="1210" y="495" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndReject" bpmnElement="End_Reject">
        <dc:Bounds x="1382" y="512" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1356" y="555" width="89" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Boundary" bpmnElement="Boundary_CutOff">
        <dc:Bounds x="974" y="164" width="32" height="32" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="914" y="203" width="71" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_start_create" bpmnElement="F_start_create">
        <di:waypoint x="206" y="300" />
        <di:waypoint x="250" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_create_reserve" bpmnElement="F_create_reserve">
        <di:waypoint x="370" y="300" />
        <di:waypoint x="410" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_reserve_fraud" bpmnElement="F_reserve_fraud">
        <di:waypoint x="530" y="300" />
        <di:waypoint x="570" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_fraud_gw" bpmnElement="F_fraud_gw">
        <di:waypoint x="700" y="300" />
        <di:waypoint x="745" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_fraud_ok" bpmnElement="F_fraud_ok">
        <di:waypoint x="795" y="300" />
        <di:waypoint x="1145" y="300" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="949" y="282" width="52" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_fraud_reject" bpmnElement="F_fraud_reject">
        <di:waypoint x="770" y="325" />
        <di:waypoint x="770" y="530" />
        <di:waypoint x="945" y="530" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="786" y="503" width="67" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_fraud_manual" bpmnElement="F_fraud_manual">
        <di:waypoint x="770" y="275" />
        <di:waypoint x="770" y="140" />
        <di:waypoint x="840" y="140" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="779" y="234" width="81" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_manual_gw" bpmnElement="F_manual_gw">
        <di:waypoint x="990" y="140" />
        <di:waypoint x="1040" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_cutoff" bpmnElement="F_cutoff_merge">
        <di:waypoint x="990" y="196" />
