        <di:waypoint x="1660" y="215" />
        <di:waypoint x="1702" y="215" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_reverse_refund" bpmnElement="F_reverse_refund">
        <di:waypoint x="1660" y="405" />
        <di:waypoint x="1700" y="405" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_refund_notify_comp" bpmnElement="F_refund_notify_comp">
        <di:waypoint x="1830" y="405" />
        <di:waypoint x="1870" y="405" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_comp_end" bpmnElement="F_comp_end">
        <di:waypoint x="2000" y="405" />
        <di:waypoint x="2042" y="405" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_reject_refund" bpmnElement="F_reject_refund">
        <di:waypoint x="995" y="530" />
        <di:waypoint x="1040" y="530" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_refund_notify_rej" bpmnElement="F_refund_notify_rej">
        <di:waypoint x="1170" y="530" />
        <di:waypoint x="1210" y="530" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_notify_end_rej" bpmnElement="F_notify_end_rej">
        <di:waypoint x="1340" y="530" />
        <di:waypoint x="1382" y="530" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
