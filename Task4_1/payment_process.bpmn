        <di:waypoint x="1080" y="515" />
        <di:waypoint x="1080" y="555" />
        <di:waypoint x="1150" y="555" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_cancel_join" bpmnElement="F_cancel_join">
        <di:waypoint x="1270" y="430" />
        <di:waypoint x="1355" y="430" />
        <di:waypoint x="1355" y="465" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_notifyrej_join" bpmnElement="F_notify_reject_join">
        <di:waypoint x="1290" y="555" />
        <di:waypoint x="1355" y="555" />
        <di:waypoint x="1355" y="515" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_rejjoin_end" bpmnElement="F_join_end_reject">
        <di:waypoint x="1380" y="490" />
        <di:waypoint x="1420" y="490" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
